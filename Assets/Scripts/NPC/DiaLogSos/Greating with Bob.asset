  lines:
  - speaker: {fileID: 11400000, guid: 3a05d63c7fbe11e4b8b718b2a4cffe6c, type: 2}
    text: Hey, Night Runner! I've been waiting for you!
  - speaker: {fileID: 11400000, guid: f1a4ea5cda80dbc4a8a9c3ba504f98ef, type: 2}
    text: What do you want from me?
  - speaker: {fileID: 11400000, guid: 3a05d63c7fbe11e4b8b718b2a4cffe6c, type: 2}
    text: Recently, many goblins have been appearing again
  - speaker: {fileID: 11400000, guid: 3a05d63c7fbe11e4b8b718b2a4cffe6c, type: 2}
    text: We need someone to kill them,you want to do this?????
  - speaker: {fileID: 11400000, guid: 3a05d63c7fbe11e4b8b718b2a4cffe6c, type: 2}
    text: I can give you some glods or an tool
  hasQuest: 1
  questID: quest_goblin_01
  questDescription: Kill 7 goblins
  goldReward: 20
  expReward: 3
  equipmentReward: Tool
